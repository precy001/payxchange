# ---- App ----
NODE_ENV=development
PORT=3000

# ---- Datastores (match docker-compose.yml) ----
DATABASE_URL=postgresql://scanpay:scanpay_dev_pw@localhost:5432/scanpay
REDIS_URL=redis://localhost:6379

# ---- Nomba ----
# In sandbox you use TEST API keys from the dashboard. Confirm the exact test
# base URL in Nomba's "Environment" docs; production is https://api.nomba.com/v1
NOMBA_BASE_URL=https://api.nomba.com/v1
NOMBA_CLIENT_ID=replace-with-your-client-id
NOMBA_CLIENT_SECRET=replace-with-your-client-secret
# The parent account id of your business, sent as the `accountId` header.
NOMBA_ACCOUNT_ID=replace-with-your-account-id
# From dashboard -> Webhook & API Keys. Used to verify webhook HMAC signatures.
NOMBA_WEBHOOK_SIGNATURE_KEY=replace-with-your-signature-key
# Confirm the exact algorithm Nomba uses for the webhook HMAC (sha256 assumed).
NOMBA_WEBHOOK_SIG_ALGO=sha256


